<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= it.name %> — Teeline</title>
    <meta name="description" content="<%= it.description %>" />
  </head>
  <body>
    <div id="topbar"></div>
    <div class="docs-layout">
      <aside class="docs-sidebar">
        <nav id="algo-sidebar" aria-label="Algorithms"></nav>
      </aside>
      <main class="docs-main">

        <nav aria-label="breadcrumb">
          <ul>
            <li><a href="/">teeline</a></li>
            <li>Algorithms</li>
            <li><%= it.name %></li>
          </ul>
        </nav>

        <% if (it.typeBadge) { %>
        <p class="docs-type-badge"><%= it.typeBadge %></p>
        <% } %>
        <% if (it.hasExplainer) { %>
        <a class="docs-explainer-cta" href="/algorithms/<%= it.solverId %>/explainer/">▶ Open interactive explainer →</a>
        <% } %>
        <%~ it.bodyHtml %>
      </main>
    </div>
    <script type="module" src="/src/docs-init.ts"></script>
  </body>
</html>
